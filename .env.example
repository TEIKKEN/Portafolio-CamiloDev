# Copia este archivo a .env y no lo subas al repositorio.
# El ID de Formspree no es exactamente un "secreto" (Formspree está
# diseñado para usarse desde el cliente), pero moverlo a env var evita
# hardcodear la URL en el código y te permite tener endpoints distintos
# para staging/producción si algún día lo necesitas.

VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/mlgqgpkp